<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">

<style>
    /* ══════════════════════════════════════════
       UNIFIED FOOTER — Tek footer, üç katman
       ══════════════════════════════════════════ */
    :root {
        --fn: 'Plus Jakarta Sans', sans-serif;
        --navy: #0b1730;
        --navy-mid: #142040;
        --navy-light: #1e3060;
        --amber: #f5c518;
        --amber-deep: #d4a80e;
        --amber-glow: rgba(245,197,24,.12);
        --amber-border: rgba(245,197,24,.22);
        --white: #ffffff;
        --text-soft: rgba(255,255,255,.58);
        --text-muted: rgba(255,255,255,.35);
        --border: rgba(255,255,255,.08);
        --dest-bg: #0e1e3a; /* destinasyon şeridi */
        --nav-bg: #0b1730; /* ana footer gövdesi */
        --copy-bg: #060f22; /* copyright şeridi  */
    }

    /* ── Genel kapsayıcı ── */
    .footer-area {
        font-family: var(--fn);
        background: var(--nav-bg);
    }

    /* ════════════════════════════════
       KATMAN 1 — Destinasyon Linkleri
       ════════════════════════════════ */
    .footer-dest {
        background: var(--dest-bg);
        border-bottom: 1px solid var(--border);
        padding: 44px 0 40px;
    }

    .dest-section-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--amber);
        margin-bottom: 14px;
    }

        .dest-section-label::before {
            content: '';
            display: block;
            width: 18px;
            height: 2px;
            border-radius: 2px;
            background: var(--amber);
        }

    .dest-divider {
        height: 1px;
        background: var(--border);
        margin: 0 0 28px;
    }

    .dest-link-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

        .dest-link-list a {
            font-size: 12.5px;
            color: var(--text-soft);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: color .16s ease, gap .16s ease;
            line-height: 1.4;
        }

            .dest-link-list a i {
                font-size: 10px;
                color: var(--amber-deep);
                opacity: 0;
                transition: opacity .16s ease;
            }

            .dest-link-list a:hover {
                color: var(--amber);
                gap: 9px;
                text-decoration: none;
            }

                .dest-link-list a:hover i {
                    opacity: 1;
                }

    /* ════════════════════════════════
       KATMAN 2 — Ana Footer Gövdesi
       ════════════════════════════════ */
    .footer-top {
        padding: 56px 0 48px;
        background: var(--nav-bg);
    }

    /* Logo */
    .footer-logo {
        margin-bottom: 20px;
    }

        .footer-logo a {
            display: inline-block;
        }

        .footer-logo img {
            max-height: 44px;
        }

    /* Logo placeholder (logo.png yokken) */
    .footer-logo-text {
        font-size: 24px;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -.02em;
    }

        .footer-logo-text span {
            color: var(--amber);
        }

    .footer-content p {
        font-size: 13.5px;
        color: var(--text-soft);
        line-height: 1.7;
        margin-bottom: 20px;
    }

    /* Sosyal medya */
    .footer-social {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 8px;
    }

        .footer-social li a {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            border: 1px solid var(--border);
            background: rgba(255,255,255,.04);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-soft);
            font-size: 14px;
            transition: all .2s ease;
            text-decoration: none;
        }

            .footer-social li a:hover {
                background: var(--amber);
                border-color: var(--amber);
                color: var(--navy);
                text-decoration: none;
            }

    /* Widget başlığı */
    .fw-title {
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
    }

        .fw-title .title {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--white);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .fw-title .title::before {
                content: '';
                display: block;
                width: 3px;
                height: 14px;
                border-radius: 2px;
                background: var(--amber);
                flex-shrink: 0;
            }

    /* Link listesi */
    .fw-link ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 9px;
    }

        .fw-link ul li a {
            font-size: 13px;
            color: var(--text-soft);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            transition: color .16s ease, gap .16s ease;
            line-height: 1.4;
        }

            .fw-link ul li a::before {
                content: '';
                display: block;
                width: 5px;
                height: 1px;
                background: var(--amber);
                flex-shrink: 0;
                opacity: 0;
                transition: opacity .16s ease;
            }

            .fw-link ul li a:hover {
                color: var(--amber);
                gap: 10px;
                text-decoration: none;
            }

                .fw-link ul li a:hover::before {
                    opacity: 1;
                }

    /* İletişim alanı */
    .footer-contact p {
        font-size: 13px;
        color: var(--text-soft);
        margin-bottom: 10px;
        line-height: 1.6;
    }

    .footer-contact .contact-phone {
        font-size: 22px;
        font-weight: 800;
        color: var(--white);
        text-decoration: none;
        display: block;
        margin-bottom: 6px;
        transition: color .16s ease;
        letter-spacing: -.02em;
    }

        .footer-contact .contact-phone:hover {
            color: var(--amber);
            text-decoration: none;
        }

    .footer-contact .contact-email {
        font-size: 13px;
        color: var(--amber);
        text-decoration: none;
        display: block;
        margin-bottom: 18px;
        transition: opacity .16s ease;
    }

        .footer-contact .contact-email:hover {
            opacity: .75;
            text-decoration: none;
        }

    /* Newsletter formu */
    .newsletter-form {
        display: flex;
        gap: 0;
        background: rgba(255,255,255,.06);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        transition: border-color .2s ease;
    }

        .newsletter-form:focus-within {
            border-color: rgba(245,197,24,.4);
        }

        .newsletter-form input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            padding: 11px 14px;
            font-size: 13px;
            color: var(--white);
            font-family: var(--fn);
        }

            .newsletter-form input::placeholder {
                color: var(--text-muted);
            }

        .newsletter-form button {
            background: var(--amber);
            border: none;
            padding: 0 16px;
            cursor: pointer;
            color: var(--navy);
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s ease;
            flex-shrink: 0;
        }

            .newsletter-form button:hover {
                background: var(--amber-deep);
            }

    /* ════════════════════════════════
       KATMAN 3 — Copyright
       ════════════════════════════════ */
    .footer-bottom {
        background: var(--copy-bg);
        padding: 16px 0;
        border-top: 1px solid var(--border);
    }

    .copyright-text p {
        font-size: 12.5px;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
    }

        .copyright-text p span {
            color: var(--amber);
            font-weight: 600;
        }

    .footer-bottom-links {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 0;
    }

        .footer-bottom-links a {
            font-size: 12px;
            color: var(--text-muted);
            text-decoration: none;
            padding: 2px 10px;
            border-right: 1px solid var(--border);
            transition: color .15s ease;
            line-height: 1.5;
        }

            .footer-bottom-links a:last-child {
                border-right: none;
            }

            .footer-bottom-links a:hover {
                color: var(--amber);
                text-decoration: none;
            }

    /* ── Responsive ── */
    @@media (max-width: 767px) {
        .footer-dest .col-md-4

    {
        margin-bottom: 28px;
    }

    .footer-dest .col-md-4:last-child {
        margin-bottom: 0;
    }

    .footer-bottom-links {
        justify-content: flex-start;
        margin-top: 8px;
    }

    }
</style>

