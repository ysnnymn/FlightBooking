@model FlightBooking.Dtos.BookingDtos.CreateBookingDto

@{
    ViewData["Title"] = "Rezervasyon Oluştur";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";
}

<main class="main-content" id="main-content">
    <div class="container-fluid mt-4 px-4">

        @* ── Sayfa Başlığı ── *@
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1" style="font-size:13px;">
                        <li class="breadcrumb-item">
                            <a href="#" class="text-decoration-none text-muted">Dashboard</a>
                        </li>
                        <li class="breadcrumb-item">
                            <a asp-area="Admin" asp-controller="Bookings" asp-action="BookingList"
                               class="text-decoration-none text-muted">Rezervasyonlar</a>
                        </li>
                        <li class="breadcrumb-item active">Yeni Rezervasyon</li>
                    </ol>
                </nav>
                <h4 class="fw-bold mb-0" style="color:#0f172a;">Rezervasyon Oluştur</h4>
                <p class="text-muted mb-0" style="font-size:13px;">
                    Yeni bir uçuş rezervasyonu oluşturmak için formu doldurun.
                </p>
            </div>
            <a asp-area="Admin" asp-controller="Bookings" asp-action="BookingList"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Geri Dön
            </a>
        </div>

        @* ── Validation Summary ── *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 d-flex gap-2 align-items-start mb-4"
                 style="border-radius:12px;font-size:13px;">
                <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                <div>
                    <strong>Lütfen aşağıdaki hataları düzeltin:</strong>
                    <asp-validation-summary asp-validation-summary="All" class="mt-1 mb-0" />
                </div>
            </div>
        }
        @* asp-area="Admin"
              asp-controller="Booking"
              asp-action="CreateBooking" *@
        @* ── FORM ── *@
        <form method="post"
              id="bookingForm">

            @Html.AntiForgeryToken()

            @* FlightId hidden *@
            <input type="hidden" asp-for="FlightId" value="@ViewBag.id" />

            <div class="row g-4">

                @* ════════════════════════════════════
                   SOL KOLON
                ════════════════════════════════════ *@
                <div class="col-12 col-xl-8">

                    @* ── 1. Uçuş Bilgileri (readonly) ── *@
                    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
                        <div class="card-header bg-white border-bottom py-3 px-4"
                             style="border-radius:14px 14px 0 0;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="d-flex align-items-center justify-content-center rounded-3"
                                     style="width:34px;height:34px;background:#eff6ff;">
                                    <i class="bi bi-airplane-fill text-primary" style="font-size:15px;"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0" style="color:#0f172a;">Uçuş Bilgileri</h6>
                                    <small class="text-muted">Seçilen uçuşa ait bilgiler</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-body px-4 py-4">
                            <div class="row g-3">
                                <div class="col-md-3 col-6">
                                    <label class="form-label fw-semibold text-muted"
                                           style="font-size:11px;letter-spacing:.5px;text-transform:uppercase;">
                                        Uçuş No
                                    </label>
                                    <input type="text"
                                           class="form-control form-control-sm bg-light border-0 fw-bold"
                                           value="@ViewBag.FlightNumber" readonly
                                           style="border-radius:8px;font-size:14px;color:#0f172a;" />
                                </div>
                                <div class="col-md-3 col-6">
                                    <label class="form-label fw-semibold text-muted"
                                           style="font-size:11px;letter-spacing:.5px;text-transform:uppercase;">
                                        Kalkış
                                    </label>
                                    <input type="text"
                                           class="form-control form-control-sm bg-light border-0"
                                           value="@ViewBag.DepartureAirportCode - @ViewBag.DepartureAirportName"
                                           readonly
                                           style="border-radius:8px;font-size:13px;color:#0f172a;" />
                                </div>
                                <div class="col-md-3 col-6">
                                    <label class="form-label fw-semibold text-muted"
                                           style="font-size:11px;letter-spacing:.5px;text-transform:uppercase;">
                                        Varış
                                    </label>
                                    <input type="text"
                                           class="form-control form-control-sm bg-light border-0"
                                           value="@ViewBag.ArrivalAirportCode - @ViewBag.ArrivalAirportName"
                                           readonly
                                           style="border-radius:8px;font-size:13px;color:#0f172a;" />
                                </div>
                                <div class="col-md-3 col-6">
                                    <label class="form-label fw-semibold text-muted"
                                           style="font-size:11px;letter-spacing:.5px;text-transform:uppercase;">
                                        Tarih
                                    </label>
                                    <input type="text"
                                           class="form-control form-control-sm bg-light border-0"
                                           value="@(((DateTime)ViewBag.DepartureTime).ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR")))"
                                           readonly
                                           style="border-radius:8px;font-size:13px;color:#0f172a;" />
                                </div>
                            </div>

                            @* Görsel uçuş özeti *@
                            <div class="mt-3 p-3 rounded-3 d-flex align-items-center gap-3 flex-wrap"
                                 style="background:#f8fafc;border:1px solid #f1f5f9;">
                                <span class="badge fw-bold px-3 py-2 rounded-3"
                                      style="background:#1a2e4a;font-size:12px;">
                                    @ViewBag.AirlineCode
                                </span>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-bold" style="font-size:18px;color:#0f172a;">
                                        @ViewBag.DepartureAirportCode
                                    </span>
                                    <div class="d-flex align-items-center gap-1 text-muted">
                                        <div style="width:28px;height:1px;background:#e2e8f0;"></div>
                                        <i class="bi bi-airplane-fill"
                                           style="font-size:13px;color:#3b82f6;"></i>
                                        <div style="width:28px;height:1px;background:#e2e8f0;"></div>
                                    </div>
                                    <span class="fw-bold" style="font-size:18px;color:#0f172a;">
                                        @ViewBag.ArrivalAirportCode
                                    </span>
                                </div>
                                <span class="text-muted" style="font-size:13px;">
                                    @(((DateTime)ViewBag.DepartureTime).ToString("HH:mm")) →
                                    @(((DateTime)ViewBag.ArrivalTime).ToString("HH:mm"))
                                </span>
                                <span class="ms-auto badge bg-success-subtle text-success fw-semibold px-3 py-2 rounded-3">
                                    <i class="bi bi-circle-fill me-1" style="font-size:7px;"></i> Planlandı
                                </span>
                            </div>
                        </div>
                    </div>

                    @* ── 2. İletişim Bilgileri ── *@
                    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
                        <div class="card-header bg-white border-bottom py-3 px-4"
                             style="border-radius:14px 14px 0 0;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="d-flex align-items-center justify-content-center rounded-3"
                                     style="width:34px;height:34px;background:#f0fdf4;">
                                    <i class="bi bi-person-lines-fill text-success"
                                       style="font-size:15px;"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0" style="color:#0f172a;">İletişim Bilgileri</h6>
                                    <small class="text-muted">Rezervasyon sahibine ait bilgiler</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-body px-4 py-4">
                            <div class="row g-3">

                                @* ContactName *@
                                <div class="col-md-4">
                                    <label asp-for="ContactName" class="form-label fw-semibold"
                                           style="font-size:12.5px;color:#374151;">
                                        Ad Soyad <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light border-end-0"
                                              style="border-radius:8px 0 0 8px;border-color:#e5e7eb;">
                                            <i class="bi bi-person text-muted"></i>
                                        </span>
                                        <input asp-for="ContactName"
                                               type="text"
                                               class="form-control border-start-0"
                                               placeholder="Ahmet Yılmaz"
                                               style="border-radius:0 8px 8px 0;border-color:#e5e7eb;font-size:13.5px;" />
                                    </div>
                                    <span asp-validation-for="ContactName"
                                          class="text-danger" style="font-size:11.5px;"></span>
                                </div>

                                @* ContactEmail *@
                                <div class="col-md-4">
                                    <label asp-for="ContactEmail" class="form-label fw-semibold"
                                           style="font-size:12.5px;color:#374151;">
                                        E-posta <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light border-end-0"
                                              style="border-radius:8px 0 0 8px;border-color:#e5e7eb;">
                                            <i class="bi bi-envelope text-muted"></i>
                                        </span>
                                        <input asp-for="ContactEmail"
                                               type="email"
                                               class="form-control border-start-0"
                                               placeholder="ornek@email.com"
                                               style="border-radius:0 8px 8px 0;border-color:#e5e7eb;font-size:13.5px;" />
                                    </div>
                                    <span asp-validation-for="ContactEmail"
                                          class="text-danger" style="font-size:11.5px;"></span>
                                </div>

                                @* ContactPhone *@
                                <div class="col-md-4">
                                    <label asp-for="ContactPhone" class="form-label fw-semibold"
                                           style="font-size:12.5px;color:#374151;">
                                        Telefon <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light border-end-0"
                                              style="border-radius:8px 0 0 8px;border-color:#e5e7eb;">
                                            <i class="bi bi-telephone text-muted"></i>
                                        </span>
                                        <input asp-for="ContactPhone"
                                               type="tel"
                                               class="form-control border-start-0"
                                               placeholder="+90 5XX XXX XX XX"
                                               style="border-radius:0 8px 8px 0;border-color:#e5e7eb;font-size:13.5px;" />
                                    </div>
                                    <span asp-validation-for="ContactPhone"
                                          class="text-danger" style="font-size:11.5px;"></span>
                                </div>

                            </div>
                        </div>
                    </div>

                    @* ── 3. Yolcu Bilgileri ── *@
                    <div class="card border-0 shadow-sm" style="border-radius:14px;">
                        <div class="card-header bg-white border-bottom py-3 px-4"
                             style="border-radius:14px 14px 0 0;">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="d-flex align-items-center justify-content-center rounded-3"
                                         style="width:34px;height:34px;background:#fffbeb;">
                                        <i class="bi bi-people-fill text-warning"
                                           style="font-size:15px;"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0" style="color:#0f172a;">Yolcu Bilgileri</h6>
                                        <small class="text-muted">Her yolcu için bilgileri ayrı ayrı girin</small>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-primary btn-sm px-3"
                                        onclick="addPassenger()"
                                        style="border-radius:8px;">
                                    <i class="bi bi-plus-lg me-1"></i> Yolcu Ekle
                                </button>
                            </div>
                        </div>
                        <div class="card-body px-4 py-4">
                            <div id="passengerList"></div>
                        </div>
                    </div>

                </div>

                @* ════════════════════════════════════
                   SAĞ KOLON — Özet
                ════════════════════════════════════ *@
                <div class="col-12 col-xl-4">
                    <div style="position:sticky;top:80px;">

                        @* Rezervasyon Özeti *@
                        <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
                            <div class="card-header bg-white border-bottom py-3 px-4"
                                 style="border-radius:14px 14px 0 0;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="d-flex align-items-center justify-content-center rounded-3"
                                         style="width:34px;height:34px;background:#f5f3ff;">
                                        <i class="bi bi-receipt"
                                           style="font-size:15px;color:#7c3aed;"></i>
                                    </div>
                                    <h6 class="fw-bold mb-0" style="color:#0f172a;">
                                        Rezervasyon Özeti
                                    </h6>
                                </div>
                            </div>
                            <div class="card-body px-4 py-3">

                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" style="font-size:13px;">Uçuş</span>
                                    <span class="fw-semibold" style="font-size:13px;color:#0f172a;">
                                        @ViewBag.FlightNumber
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" style="font-size:13px;">Güzergah</span>
                                    <span class="fw-semibold" style="font-size:13px;color:#0f172a;">
                                        @ViewBag.DepartureAirportCode → @ViewBag.ArrivalAirportCode
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" style="font-size:13px;">Tarih</span>
                                    <span class="fw-semibold" style="font-size:13px;color:#0f172a;">
                                        @(((DateTime)ViewBag.DepartureTime).ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR")))
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted" style="font-size:13px;">Toplam Yolcu</span>
                                    <span class="badge bg-primary rounded-pill px-3"
                                          id="totalPassengerBadge"
                                          style="font-size:12px;">0</span>
                                </div>

                                <div class="mt-3 p-3 rounded-3" style="background:#f8fafc;">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted" style="font-size:12.5px;">
                                            Yetişkin (x<span id="adultCount">0</span>)
                                        </span>
                                        <span style="font-size:12.5px;color:#374151;">
                                            <span id="adultPrice">0</span> EUR
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2"
                                         id="childRow" style="display:none;">
                                        <span class="text-muted" style="font-size:12.5px;">
                                            Çocuk (x<span id="childCount">0</span>)
                                        </span>
                                        <span style="font-size:12.5px;color:#374151;">
                                            <span id="childPrice">0</span> EUR
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2"
                                         id="infantRow" style="display:none;">
                                        <span class="text-muted" style="font-size:12.5px;">
                                            Bebek (x<span id="infantCount">0</span>)
                                        </span>
                                        <span style="font-size:12.5px;color:#374151;">
                                            <span id="infantPrice">0</span> EUR
                                        </span>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                                    <span class="fw-bold" style="font-size:14px;color:#0f172a;">
                                        Toplam Tutar
                                    </span>
                                    <span class="fw-bold" id="totalPrice"
                                          style="font-size:18px;color:#2563eb;">0 EUR</span>
                                </div>
                            </div>
                        </div>

                        @* Butonlar *@
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-semibold"
                                    id="submitBtn"
                                    style="border-radius:10px;padding:11px;">
                                <i class="bi bi-check-circle-fill me-2"></i> Rezervasyonu Oluştur
                            </button>
                            <a asp-area="Admin" asp-controller="Bookings" asp-action="BookingList"
                               class="btn btn-outline-secondary fw-semibold"
                               style="border-radius:10px;padding:11px;">
                                <i class="bi bi-x-circle me-2"></i> İptal
                            </a>
                        </div>

                        <div class="alert alert-info border-0 mt-3 py-2 px-3"
                             style="border-radius:10px;font-size:12px;background:#eff6ff;color:#1d4ed8;">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            Rezervasyon oluşturulduktan sonra iletişim e-postasına onay gönderilecektir.
                        </div>

                    </div>
                </div>

            </div>
        </form>
    </div>

    <script>
        /* ============================================================
           Yolcu index takibi
           ASP.NET MVC List<T> binding için name formatı:
           Passengers[0].Name, Passengers[0].Surname, ...
           Passengers[1].Name, ...
        ============================================================ */
        var passengerIndex = 0;   // her addPassenger'da artar, hiç azalmaz
        var BASE_PRICE     = 246;
        var CHILD_PRICE    = 180;
        var INFANT_PRICE   = 50;

        function addPassenger(defaultType) {
            var idx  = passengerIndex;
            var type = defaultType || 'Yetişkin';
            var prefix = 'Passengers[' + idx + ']';   // MVC binding prefix

            var card = document.createElement('div');
            card.className = 'card border-0 mb-3 passenger-card';
            card.id        = 'pcard-' + idx;
            card.style.cssText = 'border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0!important;';

            card.innerHTML =
                '<div class="card-body p-3">' +
                    '<div class="d-flex align-items-center justify-content-between mb-3">' +
                        '<div class="d-flex align-items-center gap-2">' +
                            '<div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white pax-num" ' +
                                 'style="width:28px;height:28px;font-size:12px;font-weight:700;">?</div>' +
                            '<span class="fw-semibold pax-label" style="font-size:13.5px;color:#0f172a;">Yolcu</span>' +
                        '</div>' +
                        '<button type="button" class="btn btn-danger btn-sm py-1 px-2" ' +
                                'onclick="removePassenger(' + idx + ')" style="border-radius:7px;font-size:12px;">' +
                            '<i class="bi bi-trash3-fill me-1"></i>Sil' +
                        '</button>' +
                    '</div>' +
                    '<div class="row g-3">' +

                        /* Name */
                        '<div class="col-md-3 col-6">' +
                            '<label class="form-label fw-semibold" style="font-size:11.5px;color:#6b7280;">Ad</label>' +
                            '<input type="text" name="' + prefix + '.Name" ' +
                                   'class="form-control form-control-sm" placeholder="Ad" ' +
                                   'style="border-radius:8px;border-color:#e5e7eb;font-size:13px;" required />' +
                        '</div>' +

                        /* Surname */
                        '<div class="col-md-3 col-6">' +
                            '<label class="form-label fw-semibold" style="font-size:11.5px;color:#6b7280;">Soyad</label>' +
                            '<input type="text" name="' + prefix + '.Surname" ' +
                                   'class="form-control form-control-sm" placeholder="Soyad" ' +
                                   'style="border-radius:8px;border-color:#e5e7eb;font-size:13px;" required />' +
                        '</div>' +

                        /* BirthDate */
                        '<div class="col-md-2 col-6">' +
                            '<label class="form-label fw-semibold" style="font-size:11.5px;color:#6b7280;">Doğum Tarihi</label>' +
                            '<input type="date" name="' + prefix + '.BirthDate" ' +
                                   'class="form-control form-control-sm" ' +
                                   'style="border-radius:8px;border-color:#e5e7eb;font-size:13px;" required />' +
                        '</div>' +

                        /* Gender */
                        '<div class="col-md-2 col-6">' +
                            '<label class="form-label fw-semibold" style="font-size:11.5px;color:#6b7280;">Cinsiyet</label>' +
                            '<select name="' + prefix + '.Gender" ' +
                                    'class="form-select form-select-sm" ' +
                                    'style="border-radius:8px;border-color:#e5e7eb;font-size:13px;" required>' +
                                '<option value="">Seçin</option>' +
                                '<option value="Erkek">Erkek</option>' +
                                '<option value="Kadın">Kadın</option>' +
                            '</select>' +
                        '</div>' +

                        /* PassengerType */
                        '<div class="col-md-2 col-12">' +
                            '<label class="form-label fw-semibold" style="font-size:11.5px;color:#6b7280;">Yolcu Tipi</label>' +
                            '<select name="' + prefix + '.PassengerType" ' +
                                    'class="form-select form-select-sm passenger-type-select" ' +
                                    'onchange="updateSummary()" ' +
                                    'style="border-radius:8px;border-color:#e5e7eb;font-size:13px;" required>' +
                                '<option value="Yetişkin"' + (type === 'Yetişkin' ? ' selected' : '') + '>Yetişkin</option>' +
                                '<option value="Çocuk"'   + (type === 'Çocuk'    ? ' selected' : '') + '>Çocuk</option>' +
                                '<option value="Bebek"'   + (type === 'Bebek'    ? ' selected' : '') + '>Bebek</option>' +
                            '</select>' +
                        '</div>' +

                    '</div>' +
                '</div>';

            document.getElementById('passengerList').appendChild(card);
            passengerIndex++;   // bir sonraki kart için index ilerlet
            renumberCards();
            updateSummary();
        }

        function removePassenger(idx) {
            var el = document.getElementById('pcard-' + idx);
            if (el) {
                el.remove();
                renumberCards();
                updateSummary();
            }
        }

        /* Kart numaralarını görsel olarak yeniden sırala (binding değişmez) */
        function renumberCards() {
            var cards = document.querySelectorAll('.passenger-card');
            cards.forEach(function (card, i) {
                var numEl   = card.querySelector('.pax-num');
                var lblEl   = card.querySelector('.pax-label');
                if (numEl) numEl.textContent = i + 1;
                if (lblEl) lblEl.textContent = 'Yolcu ' + (i + 1);
            });
        }

        function updateSummary() {
            var cards    = document.querySelectorAll('.passenger-card');
            var adults   = 0, children = 0, infants = 0;

            cards.forEach(function (card) {
                var sel = card.querySelector('.passenger-type-select');
                if (!sel) return;
                if      (sel.value === 'Yetişkin') adults++;
                else if (sel.value === 'Çocuk')    children++;
                else if (sel.value === 'Bebek')    infants++;
            });

            var total = adults + children + infants;
            var price = (adults  * BASE_PRICE)  +
                        (children * CHILD_PRICE) +
                        (infants  * INFANT_PRICE);

            document.getElementById('totalPassengerBadge').textContent = total;
            document.getElementById('adultCount').textContent   = adults;
            document.getElementById('adultPrice').textContent   = adults   * BASE_PRICE;
            document.getElementById('childCount').textContent   = children;
            document.getElementById('childPrice').textContent   = children * CHILD_PRICE;
            document.getElementById('infantCount').textContent  = infants;
            document.getElementById('infantPrice').textContent  = infants  * INFANT_PRICE;
            document.getElementById('totalPrice').textContent   = price + ' EUR';

            document.getElementById('childRow').style.display  = children > 0 ? 'flex' : 'none';
            document.getElementById('infantRow').style.display = infants  > 0 ? 'flex' : 'none';

            /* En az 1 yolcu yoksa submit'i devre dışı bırak */
            document.getElementById('submitBtn').disabled = total === 0;
        }

        /* Submit öncesi yolcu kontrolü */
        document.getElementById('bookingForm').addEventListener('submit', function (e) {
            var cards = document.querySelectorAll('.passenger-card');
            if (cards.length === 0) {
                e.preventDefault();
                alert('Lütfen en az bir yolcu ekleyin.');
            }
        });

        /* Sayfa açılınca 1 yolcu varsayılan gelsin */
        document.addEventListener('DOMContentLoaded', function () {
            addPassenger('Yetişkin');
        });
    </script>

</main>